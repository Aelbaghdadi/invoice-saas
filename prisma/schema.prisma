generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  WORKER
  CLIENT
}

enum InvoiceType {
  PURCHASE
  SALE
}

enum InvoiceStatus {
  UPLOADED
  ANALYZING
  ANALYZED
  OCR_ERROR
  VALIDATED
  REJECTED
  EXPORTED
}

model AdvisoryFirm {
  id        String   @id @default(cuid())
  name      String
  cif       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  clients Client[]
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String
  role           Role
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  advisoryFirmId String?
  advisoryFirm   AdvisoryFirm? @relation(fields: [advisoryFirmId], references: [id])

  assignedClients WorkerClientAssignment[]
  clientProfile   Client?                  @relation("ClientUser")
  auditLogs       AuditLog[]
}

model Client {
  id                String   @id @default(cuid())
  name              String
  cif               String   @unique
  email             String   @unique
  accountingProgram String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  advisoryFirmId String
  advisoryFirm   AdvisoryFirm @relation(fields: [advisoryFirmId], references: [id])

  userId String? @unique
  user   User?   @relation("ClientUser", fields: [userId], references: [id])

  assignedWorkers WorkerClientAssignment[]
  invoices        Invoice[]
  periodClosures  PeriodClosure[]
}

model WorkerClientAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  workerId String
  worker   User   @relation(fields: [workerId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  @@unique([workerId, clientId])
}

model Invoice {
  id          String        @id @default(cuid())
  filename    String
  storageKey  String
  fileType    String
  fileHash    String?
  type        InvoiceType
  status      InvoiceStatus @default(UPLOADED)
  periodMonth Int
  periodYear  Int

  // Datos finales (editados por gestor o copiados de OCR)
  issuerName    String?
  issuerCif     String?
  receiverName  String?
  receiverCif   String?
  invoiceNumber String?
  invoiceDate   DateTime?
  taxBase       Decimal?  @db.Decimal(12, 2)
  vatRate       Decimal?  @db.Decimal(5, 2)
  vatAmount     Decimal?  @db.Decimal(12, 2)
  irpfRate      Decimal?  @db.Decimal(5, 2)
  irpfAmount    Decimal?  @db.Decimal(12, 2)
  totalAmount   Decimal?  @db.Decimal(12, 2)
  isValid       Boolean?

  // Gestion de estado avanzada
  rejectionReason String?
  reviewedBy      String?
  ocrAttempts     Int       @default(0)
  lastOcrError    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId      String
  client        Client     @relation(fields: [clientId], references: [id])
  auditLogs     AuditLog[]
  extractions   InvoiceExtraction[]
  statusHistory InvoiceStatusHistory[]

  exportBatchId String?
  exportBatch   ExportBatch? @relation(fields: [exportBatchId], references: [id])
}

model InvoiceExtraction {
  id        String @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  // Datos brutos extraidos por OCR
  rawResponse   String?   // JSON completo de GPT
  source        String    // "gpt4o" | "xml_parse" | "manual"
  issuerName    String?
  issuerCif     String?
  receiverName  String?
  receiverCif   String?
  invoiceNumber String?
  invoiceDate   DateTime?
  taxBase       Decimal?  @db.Decimal(12, 2)
  vatRate       Decimal?  @db.Decimal(5, 2)
  vatAmount     Decimal?  @db.Decimal(12, 2)
  irpfRate      Decimal?  @db.Decimal(5, 2)
  irpfAmount    Decimal?  @db.Decimal(12, 2)
  totalAmount   Decimal?  @db.Decimal(12, 2)
  isValid       Boolean?

  createdAt DateTime @default(now())
}

model InvoiceStatusHistory {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])

  fromStatus InvoiceStatus?
  toStatus   InvoiceStatus
  reason     String?
  changedBy  String?

  createdAt DateTime @default(now())
}

model ExportBatch {
  id           String   @id @default(cuid())
  format       String   // "sage50" | "contasol" | "a3con"
  clientId     String?
  periodMonth  Int?
  periodYear   Int?
  invoiceType  String?  // "ALL" | "PURCHASE" | "SALE"
  invoiceCount Int
  userId       String
  createdAt    DateTime @default(now())

  invoices Invoice[]
}

model AuditLog {
  id        String   @id @default(cuid())
  field     String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model PeriodClosure {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  month       Int
  year        Int
  closedBy    String
  closedAt    DateTime @default(now())
  reopenedAt  DateTime?
  reopenedBy  String?
  reminderSent Boolean @default(false)

  @@unique([clientId, month, year])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
