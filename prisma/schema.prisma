generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  WORKER
  CLIENT
}

enum InvoiceType {
  PURCHASE
  SALE
}

enum InvoiceStatus {
  UPLOADED
  ANALYZING
  ANALYZED
  PENDING_REVIEW
  NEEDS_ATTENTION
  OCR_ERROR
  VALIDATED
  REJECTED
  EXPORTED
}

enum RejectionCategory {
  ILLEGIBLE
  INCOMPLETE
  WRONG_PERIOD
  DUPLICATE
  OTHER
}

enum IssueType {
  OCR_FAILED
  LOW_CONFIDENCE
  POSSIBLE_DUPLICATE
  MATH_MISMATCH
  MANUAL
}

enum IssueStatus {
  OPEN
  RESOLVED
  DISMISSED
}

model AdvisoryFirm {
  id        String   @id @default(cuid())
  name      String
  cif       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  clients Client[]
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String
  role           Role
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  advisoryFirmId String?
  advisoryFirm   AdvisoryFirm? @relation(fields: [advisoryFirmId], references: [id])

  assignedClients WorkerClientAssignment[]
  clientProfile   Client?                  @relation("ClientUser")
  auditLogs       AuditLog[]
}

model Client {
  id                String   @id @default(cuid())
  name              String
  cif               String   @unique
  email             String   @unique
  accountingProgram String?
  exportConfig      Json?     // { encoding, delimiter, dateFormat, accountLength }
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  advisoryFirmId String
  advisoryFirm   AdvisoryFirm @relation(fields: [advisoryFirmId], references: [id])

  userId String? @unique
  user   User?   @relation("ClientUser", fields: [userId], references: [id])

  assignedWorkers WorkerClientAssignment[]
  documents       Document[]
  invoices        Invoice[]
  periodClosures  PeriodClosure[]
  accountEntries  AccountEntry[]
}

model WorkerClientAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  workerId String
  worker   User   @relation(fields: [workerId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([workerId, clientId])
}

model Document {
  id         String   @id @default(cuid())
  filename   String
  storageKey String
  fileType   String
  fileHash   String?
  sizeBytes  Int?
  uploadedBy String?
  createdAt  DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  invoices Invoice[]
}

model Invoice {
  id          String        @id @default(cuid())
  filename    String
  storageKey  String
  fileType    String
  fileHash    String?
  type        InvoiceType
  status      InvoiceStatus @default(UPLOADED)
  periodMonth Int
  periodYear  Int

  // Datos finales (editados por gestor o copiados de OCR)
  issuerName    String?
  issuerCif     String?
  receiverName  String?
  receiverCif   String?
  invoiceNumber String?
  invoiceDate   DateTime?
  taxBase       Decimal?  @db.Decimal(12, 2)
  vatRate       Decimal?  @db.Decimal(5, 2)
  vatAmount     Decimal?  @db.Decimal(12, 2)
  irpfRate      Decimal?  @db.Decimal(5, 2)
  irpfAmount    Decimal?  @db.Decimal(12, 2)
  totalAmount   Decimal?  @db.Decimal(12, 2)
  isValid       Boolean?

  // Cuentas contables asignadas (del plan de cuentas)
  supplierAccount String?   // Cuenta proveedor 400.xxxxx / 410.xxxxx
  expenseAccount  String?   // Cuenta gasto/ingreso 6xx.xxxxx / 7xx.xxxxx

  // Gestion de estado avanzada
  rejectionReason   String?
  rejectionCategory RejectionCategory?
  reviewedBy        String?

  // Re-subida: vincula con la factura rechazada original
  replacesId String?  @unique
  replaces   Invoice? @relation("ReplacedBy", fields: [replacesId], references: [id])
  replacedBy Invoice? @relation("ReplacedBy")

  // Periodo contable (puede diferir del periodo de subida)
  accountingPeriodMonth Int?
  accountingPeriodYear  Int?
  ocrAttempts     Int       @default(0)
  lastOcrError    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId      String
  client        Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  documentId    String?
  document      Document?  @relation(fields: [documentId], references: [id])

  auditLogs     AuditLog[]
  extractions   InvoiceExtraction[]
  statusHistory InvoiceStatusHistory[]
  issues        InvoiceIssue[]
  exportBatchItems ExportBatchItem[]

  exportBatchId String?
  exportBatch   ExportBatch? @relation(fields: [exportBatchId], references: [id])

  @@index([clientId, status])
  @@index([issuerCif])
  @@index([periodMonth, periodYear])
}

model InvoiceExtraction {
  id        String @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Datos brutos extraidos por OCR
  rawResponse   String?   // JSON completo de respuesta OCR
  source        String    // "document_ai" | "xml_parse" | "manual"
  confidence    Json?     // { campo: 0.0-1.0 } scores de confianza OCR

  // OCR job tracking
  ocrStartedAt  DateTime?  // Inicio del procesamiento OCR
  ocrFinishedAt DateTime?  // Fin del procesamiento (exito o error)
  ocrDurationMs Int?       // Duracion en milisegundos
  isReprocess   Boolean    @default(false) // true si fue reproceso manual
  issuerName    String?
  issuerCif     String?
  receiverName  String?
  receiverCif   String?
  invoiceNumber String?
  invoiceDate   DateTime?
  taxBase       Decimal?  @db.Decimal(12, 2)
  vatRate       Decimal?  @db.Decimal(5, 2)
  vatAmount     Decimal?  @db.Decimal(12, 2)
  irpfRate      Decimal?  @db.Decimal(5, 2)
  irpfAmount    Decimal?  @db.Decimal(12, 2)
  totalAmount   Decimal?  @db.Decimal(12, 2)
  isValid       Boolean?

  createdAt DateTime @default(now())
}

model InvoiceStatusHistory {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  fromStatus InvoiceStatus?
  toStatus   InvoiceStatus
  reason     String?
  changedBy  String?

  createdAt DateTime @default(now())
}

model ExportBatch {
  id           String   @id @default(cuid())
  format       String   // "sage50" | "contasol" | "a3con"
  clientId     String?
  periodMonth  Int?
  periodYear   Int?
  invoiceType  String?  // "ALL" | "PURCHASE" | "SALE"
  invoiceCount Int
  userId       String
  createdAt    DateTime @default(now())

  invoices Invoice[]
  items    ExportBatchItem[]
}

model ExportBatchItem {
  id            String      @id @default(cuid())
  exportBatchId String
  exportBatch   ExportBatch @relation(fields: [exportBatchId], references: [id], onDelete: Restrict)
  invoiceId     String
  invoice       Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  snapshot      String      // JSON snapshot de los datos de la factura al exportar
  createdAt     DateTime    @default(now())

  @@unique([exportBatchId, invoiceId])
}

model InvoiceIssue {
  id          String      @id @default(cuid())
  invoiceId   String
  invoice     Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  type        IssueType
  status      IssueStatus @default(OPEN)
  description String
  field       String?
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime    @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  field     String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model PeriodClosure {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month       Int
  year        Int
  closedBy    String
  closedAt    DateTime @default(now())
  reopenedAt  DateTime?
  reopenedBy  String?
  reminderSent Boolean @default(false)

  @@unique([clientId, month, year])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AccountEntry {
  id              String   @id @default(cuid())
  nif             String
  name            String
  supplierAccount String   // Cuenta proveedor 400.xxxxx / 410.xxxxx
  expenseAccount  String   // Cuenta gasto/ingreso 6xx.xxxxx / 7xx.xxxxx
  defaultVatRate  Decimal? @db.Decimal(5, 2)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, nif])
  @@index([clientId])
}
